.DS_Store
node_modules
/build
/.svelte-kit
/package
.env
.env.*
!.env.example
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Rust / Tauri
/target
/src-tauri/target
/src-tauri/gen/schemas

# Updater signing key + passphrase — NEVER commit (pubkey lives in tauri.conf.json)
/.tauri-updater.key
/.tauri-updater.key.pub
/.tauri-updater.pass

# comfysort debug logs
*.log

# Local-only docs (internal architecture / design / handoff notes + context for
# cross-session iteration) and local dev tooling. Kept out of the public repo;
# README.md (public) lives at the root.
# Exception: docs/screenshots/ holds the README hero + screenshots (published).
/docs/*
!/docs/screenshots/
/.claude/

# Contributor entry notes (local-only)
/AGENTS.md

# Private build/release toolchain (not for public consumption)
/scripts/

# Remotion marketing-video project (local-only tooling; the published demo GIF
# and screenshots it renders live in docs/screenshots/)
/marketing/
